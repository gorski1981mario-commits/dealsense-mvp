# Next.js Frontend - Environment Variables Example
# Copy to .env.local for local development

# KWANT Backend URL (Render)
NEXT_PUBLIC_BACKEND_URL=https://dealsense-aplikacja.onrender.com

# Stripe (for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Optional: Analytics
NEXT_PUBLIC_GA_ID=
