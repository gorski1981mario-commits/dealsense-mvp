# ============================================================================
# DEALSENSE - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# Data: 21 marca 2026
# Tylko AKTYWNE zmienne - stare crawler/pricing USUNIĘTE!
# ============================================================================

# ----------------------------------------------------------------------------
# 1. GOOGLE SHOPPING API (SearchAPI.io) - GŁÓWNE ŹRÓDŁO DANYCH
# ----------------------------------------------------------------------------
GOOGLE_SHOPPING_API_KEY=your_searchapi_key_here
GOOGLE_SHOPPING_NUM_RESULTS=100
GOOGLE_SHOPPING_NUM_PAGES=1

# ----------------------------------------------------------------------------
# 2. SERPAPI (Fallback)
# ----------------------------------------------------------------------------
SERPAPI_API_KEY=your_serpapi_key_here

# ----------------------------------------------------------------------------
# 3. CRAWLER & PROXY - ZAMROŻONE (NIE UŻYWAMY!)
# ----------------------------------------------------------------------------
USE_OWN_CRAWLER=false
USE_PROXY=false

# ----------------------------------------------------------------------------
# 4. MOCK FALLBACK
# ----------------------------------------------------------------------------
USE_MOCK_FALLBACK=false

# ----------------------------------------------------------------------------
# 5. DEAL SCORE V2 (UNFAIR ADVANTAGE!)
# ----------------------------------------------------------------------------
USE_DEAL_SCORE_V2=true
USE_ROTATION_ENGINE=true
USE_LONG_TAIL_QUERIES=false
MAX_QUERY_VARIANTS=30

# ----------------------------------------------------------------------------
# 6. COST OPTIMIZATION (NAJWIĘKSZA OSZCZĘDNOŚĆ!)
# ----------------------------------------------------------------------------
# Cache First Strategy: -90% kosztów API (multi-user sharing)
USE_CACHE_FIRST=true

# Query Scoring: wybierz 5-10 najlepszych zapytań (zamiast 30-50)
USE_QUERY_SCORING=true

# Adaptive Fetch: stop gdy masz 50 ofert z wysokim score
USE_ADAPTIVE_FETCH=true

# Source Priority: cache → własne sklepy → tanie API → drogie API
USE_SOURCE_PRIORITY=true

# Adaptive Price Threshold: zamiast stałych 5%
USE_ADAPTIVE_THRESHOLD=true

# ----------------------------------------------------------------------------
# 7. CACHE CONFIGURATION
# ----------------------------------------------------------------------------
MARKET_CACHE_BYPASS=false
MARKET_LOG_SILENT=false

# ----------------------------------------------------------------------------
# 8. UPSTASH REDIS (opcjonalny - dla cache)
# ----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----------------------------------------------------------------------------
# 9. NODE ENVIRONMENT
# ----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# ============================================================================
# ZMIENNE DO USUNIĘCIA Z RENDER.COM (STARE, NIEAKTYWNE):
# ============================================================================
# ❌ CRAWLER_HEADLESS (nieaktywne - crawler zamrożony)
# ❌ CRAWLER_MAX_DOMAINS (nieaktywne - crawler zamrożony)
# ❌ CRAWLER_TIMEOUT (nieaktywne - crawler zamrożony)
# ❌ GOOGLE_SHOPPING_NUM_* (duplikaty - mamy już GOOGLE_SHOPPING_NUM_RESULTS)
# ❌ MARKET_DISK_CACHE_* (nieaktywne - używamy Redis/memory)
# ❌ MARKET_LOG_SILENT (mamy już w sekcji 7)
# ❌ PRICING_NICHE_EXCEPTION_* (stary system - mamy Deal Score V2)
# ❌ PRICING_NICHE_MIN_* (stary system - mamy Deal Score V2)
# ❌ PRICING_SCAM_MIN_* (stary system - mamy Trust Engine)
# ❌ PRICING_SELLER_* (stary system - mamy Trust Engine)
# ❌ Wszystkie zmienne PROXY_* (proxy zamrożone)
# ============================================================================

# ============================================================================
# INSTRUKCJA WDROŻENIA NA RENDER.COM:
# ============================================================================
# 1. Usuń WSZYSTKIE stare zmienne (lista powyżej)
# 2. Dodaj TYLKO te zmienne z sekcji 1-9
# 3. Uzupełnij API keys:
#    - GOOGLE_SHOPPING_API_KEY (z SearchAPI.io)
#    - SERPAPI_API_KEY (z SerpAPI)
# 4. Opcjonalnie: dodaj Upstash Redis (sekcja 8)
# 5. Deploy!
# ============================================================================
