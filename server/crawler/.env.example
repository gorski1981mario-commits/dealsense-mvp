# DealSense Crawler - Environment Configuration

# Redis (Queue + Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Proxy Configuration (CHOOSE ONE)
USE_PROXY=true
PROXY_PROVIDER=brightdata  # or 'smartproxy'

# BrightData (Luminati) - Residential Proxies
BRIGHTDATA_USERNAME=your_username_here
BRIGHTDATA_PASSWORD=your_password_here
BRIGHTDATA_PORT=22225

# SmartProxy - Alternative
SMARTPROXY_USERNAME=your_username_here
SMARTPROXY_PASSWORD=your_password_here
SMARTPROXY_PORT=7000

# Sentry Error Tracking
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Environment
NODE_ENV=production

# Monitoring
METRICS_ENABLED=true
METRICS_INTERVAL=60000

# Rate Limiting (requests per minute)
RATE_LIMIT_DEFAULT=30
RATE_LIMIT_AGGRESSIVE=50
RATE_LIMIT_CONSERVATIVE=15
RATE_LIMIT_FINANCE=10
