# Environment Configuration - Production Ready for 1M+ Users
NODE_ENV=production
PORT=3000

# API Keys
GOOGLE_SHOPPING_API_KEY=your_google_shopping_api_key_here
API_KEY=your_internal_api_key_here

# Feature Flags
USE_MOCK_FALLBACK=false

# Security & Authentication
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
CORS_ORIGIN=https://dealsense.nl,https://www.dealsense.nl

# Redis Cache (Render Redis addon or external)
REDIS_URL=redis://default:password@redis-host:6379
CACHE_TTL=300

# Stripe Payment
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here

# Sentry Error Tracking
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Logging
LOG_LEVEL=info

# Rate Limiting (100 requests per minute per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Pricing Rules - Niche Exception
PRICING_NICHE_EXCEPTION_ENABLED=true
PRICING_NICHE_EXCL=4.0
PRICING_NICHE_MIN_RATING=4.0
PRICING_NICHE_MIN_REVIEWS=30

# Pricing Rules - Scam Filter
PRICING_SCAM_MIN_R=4.0

# Pricing Rules - V2
PRICING_V2_MAX_RAT=4.6
PRICING_V2_MIN_RAT=4.0
PRICING_V2_MIN_REV=30

# Market Settings
MARKET_DISK_CACHE=1
MARKET_LOG_SILENT=1
