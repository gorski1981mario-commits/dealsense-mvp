# KWANT Backend - Environment Variables Example
# Copy this file to .env and fill in your values

# Server Configuration
PORT=10000
NODE_ENV=production

# Mock Fallback (set to false for production with real APIs)
USE_MOCK_FALLBACK=true

# Google Shopping API (SearchAPI.io)
# Get your key at: https://www.searchapi.io/
GOOGLE_SHOPPING_API_KEY=

# SerpAPI (fallback)
# Get your key at: https://serpapi.com/
SERPAPI_API_KEY=

# Upstash Redis (for KWANT queue and cache)
# Get your credentials at: https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# KWANT Configuration
GOOGLE_SHOPPING_NUM_RESULTS=100
GOOGLE_SHOPPING_NUM_PAGES=1
KWANT_ALLOW_NET=true
DEALSENSE_ALLOW_LIVE=true

# Market Cache
MARKET_DISK_CACHE_ENABLED=1
MARKET_LOG_SILENT=1

# Optional: Sentry Error Tracking
SENTRY_DSN=

# IPRoyal Proxy Configuration (Residential, High-end Pool)
# Get your credentials at: https://dashboard.iproyal.com/
# IMPORTANT: Password includes all config (country, city, session, lifetime, streaming)
# Format: password_country-nl_city-amsterdam_session-xxx_lifetime-30m_streaming-1
PROXY_HOST=geo.iproyal.com
PROXY_PORT=12321
PROXY_USERNAME=your_username_from_dashboard
PROXY_PASSWORD=your_password_country-nl_city-amsterdam_session-xxx_lifetime-30m_streaming-1
PROXY_COUNTRY=nl
PROXY_PROVIDER=iproyal
USE_PROXY=false

# Deal Score V2 Configuration (UNFAIR ADVANTAGE!)
# Enable new scoring system with trust engine, rotation, long-tail queries
USE_DEAL_SCORE_V2=true
USE_ROTATION_ENGINE=true
USE_LONG_TAIL_QUERIES=false
MAX_QUERY_VARIANTS=30

# Cost Optimization Configuration (NAJWIĘKSZA OSZCZĘDNOŚĆ!)
# Cache First Strategy: -90% kosztów API (multi-user sharing)
USE_CACHE_FIRST=true
# Query Scoring: wybierz 5-10 najlepszych zapytań (zamiast 30-50)
USE_QUERY_SCORING=true
# Adaptive Fetch: stop gdy masz 50 ofert z wysokim score
USE_ADAPTIVE_FETCH=true
# Source Priority: cache → własne sklepy → tanie API → drogie API
USE_SOURCE_PRIORITY=true
# Adaptive Price Threshold: zamiast stałych 5%
USE_ADAPTIVE_THRESHOLD=true
