# ECHO CLOUD - Environment Variables

# ============================================================================
# API KEYS
# ============================================================================

# Mixtral API (Together AI)
# Get from: https://www.together.ai/
MIXTRAL_API_KEY=your_together_ai_api_key_here

# Pinecone (Vector Database)
# Get from: https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here

# OpenAI (for embeddings)
# Get from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# DATABASE
# ============================================================================

# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database
# Render: Get from dashboard → Database → External Database URL
# Railway: Get from dashboard → PostgreSQL → Connect
DATABASE_URL=postgresql://user:password@host:5432/echo

# ============================================================================
# CONFIGURATION
# ============================================================================

# Cost Limit (per answer, in EUR)
# Default: 0.01 (1 cent)
# Adjust based on your budget
COST_LIMIT=0.01

# Mobius Loop Interval (milliseconds)
# Default: 240000 (4 minutes)
# Decrease for faster learning, increase for lower costs
MOBIUS_INTERVAL=240000

# Max Specialists
# Base: 13, Max with Gear Shift: 23
MAX_SPECIALISTS=23

# ============================================================================
# OPTIONAL
# ============================================================================

# Port (for server)
PORT=3000

# Environment
NODE_ENV=production

# Log Level
LOG_LEVEL=info
